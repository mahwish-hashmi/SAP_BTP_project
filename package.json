{
  "name": "smarthostel-btp",
  "version": "2.0.0",
  "description": "Smart Hostel Management on SAP BTP — CAP + Fiori + SQLite",
  "license": "MIT",
  "dependencies": {
    "@sap/cds": "^7.5.0",
    "express": "^4.18.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7.5.0",
    "sqlite3": "^5.1.7"
  },
  "scripts": {
    "start": "cds watch",
    "dev": "cds watch",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/hostel.db"
        }
      }
    },
    "features": {
      "assert_integrity": "db"
    }
  }
}

